      "parameters": {
        "jsCode": "const records = $input.all();\n\n// 💡 1. 識破 n8n 的「假空箱子」騙局\n// 如果是 0 條記錄，或者唯一的一條記錄是個空殼子 (裡面沒有任何 keys)\nconst isDummyEmpty = records.length === 1 && Object.keys(records[0].json).length === 0;\n\nif (records.length === 0 || isDummyEmpty) {\n    return [{ json: { report_text: \"🎉 太棒了！目前沒有任何不及格的科目！\" } }];\n}\n\nlet report = \"⚠️ **不及格科目預警**：\\n\";\nlet actualFails = 0; // 用來計數真正的不及格科目\n\n// 💡 2. 遍歷數據\nrecords.forEach(item => {\n    const data = item.json.fields || item.json; \n    \n    // 抓取真實的列名（請確保中括號裡的字跟你的 Airtable 表頭一致）\n    const subject = data['subject'] || data['科目'] || data['學科'];\n    const score = data['score'] || data['分數'] || data['成績'];\n    \n    // 🛡️ 過濾 Airtable 裡的「幽靈空白行」：如果連科目和分數都沒有，直接跳過\n    if (subject === undefined && score === undefined) return;\n\n    actualFails++;\n    report += `- ${subject || '未知科目'} (${score || 0}分)\\n`;\n});\n\n// 💡 3. 如果遍歷完發現，查出來的全是幽靈空白行，還是報喜！\nif (actualFails === 0) {\n    return [{ json: { report_text: \"🎉 太棒了！目前沒有任何不及格的科目！\" } }];\n}\n\nreturn [{ json: { report_text: report } }];"
      },
