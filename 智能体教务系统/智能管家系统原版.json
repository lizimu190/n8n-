    {
      "parameters": {
        "jsCode": "// 获取所有传入的记录\nconst allRecords = $input.all();\n\nlet totalScore = 0;\nlet highestScore = -1;\nlet validCount = 0;\nlet subjectsInfo = [];\n\n// 遍历所有的记录进行数学计算\nfor (const item of allRecords) {\n  // 🎯 核心修复：根据截图，精准提取小写的 subject 和 score\n  const score = item.json.score;\n  const subject = item.json.subject;\n\n  // 确保分数存在且是有效的数字\n  if (score !== undefined && score !== null && !isNaN(score)) {\n    const numScore = Number(score);\n    totalScore += numScore;\n    validCount++;\n    subjectsInfo.push(`【${subject}】${numScore}分`);\n\n    // 找最高分\n    if (numScore > highestScore) {\n      highestScore = numScore;\n    }\n  }\n}\n\n// 极端情况防呆：如果提取不到有效分数\nif (validCount === 0) {\n  return [{ json: { report_text: \"⚠️ 目前数据库中没有任何成绩记录，请先录入成绩！\" } }];\n}\n\n// 计算平均分 (保留两位小数)\nconst averageScore = (totalScore / validCount).toFixed(2);\n\n// 组装一份排版漂亮的 AI 汇报文案\nconst reportText = `📊 您的智能成绩单已生成！\\n\\n📚 共统计科目：${validCount} 门\\n📈 平均分：${averageScore} 分\\n🏆 最高分：${highestScore} 分\\n\\n📝 明细列表：\\n${subjectsInfo.join(\"\\n\")}`;\n\n// 将纯净的计算结果输出给下一个节点\nreturn [{\n  json: {\n    total_subjects: validCount,\n    total_score: totalScore,\n    average_score: Number(averageScore),\n    highest_score: highestScore,\n    report_text: reportText\n  }\n}];"
      },
